{
  "cli": {
    "version": ">= 21.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
       "env": {
        "EXPO_PUBLIC_API_URL": "https://gonad-atypical-lather.ngrok-free.dev/api/v1"
      }
    },
    "preview": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "autoIncrement": true,
      "distribution": "internal"
    }
  },
  "submit": {
    "production": {}
  }
}
