generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url = env("DATABASE_URL")
}

// ---- Enums ----------------------------------------------------------------------------------------------------------------------------

enum UserStatus {
    ACTIVE
    SUSPENDED
    DELETED
}

enum WalletProvider {
    PANWALLET_INTERNAL
    MPESA
    MTN_MOMO
}

enum WalletStatus {
    ACTIVE
    SUSPENDED
    CLOSED
}

enum TransactionStatus {
    PENDING
    COMPLETED
    FAILED
    REVERSED
}

enum AdminRole {
    SUPER_ADMIN
    SUPPORT
}


// ------ Models -----------------------------------------------------------------------------------------------------------------------------

model User {
    id          String      @id @default(uuid())
    phoneNumber String      @unique
    name        String
    email       String?     @unique
    password    String?
    status      UserStatus  @default (ACTIVE)
    createdAt   DateTime    @default(now())
    updatedAt   DateTime    @updatedAt

    wallets         Wallet[]
    refreshTokens   RefreshToken[]

    @@map("users")

}

model Wallet {
    id              String          @id @default(uuid())
    userId          String
    provider        WalletProvider
    walletNumber    String
    currency        String          @db.VarChar(3)
    balance         Decimal         @default(0) @db.Decimal(18,2)
    status          WalletStatus    @default(ACTIVE)
    createdAt       DateTime        @default(now())
    updatedAt       DateTime        @updatedAt

    user                    User            @relation(fields: [userId], references: [id])
    sentTransactions        Transaction[]   @relation("SenderWallet")
    receivedTransactions    Transaction[]   @relation("RecipientWallet")

    @@unique([provider, walletNumber])
    @@index([userId])
    @@map("wallets")
}

model Transaction {
    id                  String              @id @default(uuid())
    senderWalletId      String
    recipientWalletId    String?
    recipientProvider   WalletProvider
    recipientNumber     String
    providerReferenceId String?             
    amount              Decimal             @db.Decimal(18, 2)
    fee                 Decimal             @default(0) @db.Decimal(18, 2)
    exchangeRateId      String?
    status              TransactionStatus   @default(PENDING)
    failureReason       String?             
    createdAt           DateTime            @default(now())
    updatedAt           DateTime            @updatedAt

    senderWallet        Wallet          @relation("SenderWallet", fields: [senderWalletId], references: [id])
    recipientWallet     Wallet?         @relation("RecipientWallet", fields: [recipientWalletId], references: [id])
    exchangeRate        ExchangeRate?   @relation(fields: [exchangeRateId], references: [id])

    @@index([senderWalletId])
    @@index([recipientWalletId])
    @@map("transactions")
}

model ExchangeRate {
    id              String      @id @default(uuid())
    sourceCurrency  String      @db.VarChar(3)
    targetCurrency  String      @db.VarChar(3)
    rate            Decimal     @db.Decimal(18, 6)
    recordedAt      DateTime    @default(now())

    transactions Transaction[]

    @@index([sourceCurrency, targetCurrency])
    @@map("exchange_rates")
}

model RefreshToken {
    id          String      @id @default(uuid())
    userId      String
    tokenHash   String      @unique
    family      String
    revoked     Boolean     @default(false)
    expiresAt   DateTime
    createdAt   DateTime    @default(now())

    user    User    @relation(fields: [userId], references: [id])

    @@index([userId])
    @@map("refresh_tokens")    
}

model Admin {
    id          String      @id @default(uuid())
    username    String      @unique
    email       String      @unique
    password    String
    role        AdminRole   @default(SUPPORT)
    createdAt   DateTime    @default(now())
    updatedAt   DateTime    @updatedAt

    @@map("admins")
}